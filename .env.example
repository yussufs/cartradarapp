# Database (matches compose.yaml for local development)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shopify_app"

# Shopify CLI automatically sets these during `shopify app dev`:
# - SHOPIFY_API_KEY
# - SHOPIFY_API_SECRET
# - SHOPIFY_APP_URL
# - SCOPES
#
# For production, set these manually or use `shopify app env pull`

SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SCOPES=write_products
