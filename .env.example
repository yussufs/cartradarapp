# Database (matches compose.yaml for local development)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shopify_app"

# Shopify — set automatically by `shopify app dev`; required in production (Railway)
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_APP_URL="https://cartradar.dragonapps.io"
SCOPES="read_orders,read_customers"

# Amazon SES (alert emails) — IAM user needs ses:SendEmail
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
ALERT_FROM_EMAIL="alerts@cartradar.dragonapps.io"

# Shopify Billing — set to "true" on dev stores so subscriptions are test charges
BILLING_TEST_MODE="true"

# Twilio (alert SMS) — shared verified toll-free number
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
