# Database (matches compose.yaml for local development)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shopify_app"

# Shopify — set automatically by `shopify app dev`; required in production (Railway)
SHOPIFY_API_KEY=""
SHOPIFY_API_SECRET=""
SHOPIFY_APP_URL="https://cartradar.dragonapps.io"
SCOPES="read_orders,read_customers,write_draft_orders,read_products"

# Amazon SES (alert emails) — IAM user needs ses:SendEmail
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
ALERT_FROM_EMAIL="alerts@cartradar.dragonapps.io"

# Slack alerts — one-click "Connect Slack" OAuth. Create an app at
# api.slack.com/apps with the `incoming-webhook` scope and register the redirect
# URL <SHOPIFY_APP_URL>/auth/slack/callback. Leave empty to hide the Slack option.
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""

# Shopify Billing — set to "true" on dev stores so subscriptions are test charges
BILLING_TEST_MODE="true"

# Local testing harness — enables the /app/dev page + /api/dev seed endpoint.
# NEVER set this in production. In dev, alert emails are logged to the console
# when SES (ALERT_FROM_EMAIL) is not configured.
DEV_TOOLS="true"

# Optional: secret that guards POST/GET /api/cron/evaluate, for triggering the
# abandonment evaluator from an external scheduler instead of the in-process one.
# Leave unset to keep that endpoint disabled (the in-process scheduler runs anyway).
CRON_SECRET=""
